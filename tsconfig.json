{
    "compilerOptions": {
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "moduleResolution": "node",
        "module": "esnext",
        "target": "es2018",
        "lib": ["es2018", "dom"],
        "sourceMap": true,
        "declaration": true,
        "declarationDir": "typings",
        "outDir": "dist",
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts"]
}
